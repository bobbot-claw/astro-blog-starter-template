---
// AeonCircle — The Healthspan Club (Substance edition)
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>AeonCircle — Live well, for 120 years.</title>
<meta name="description" content="A membership built for your healthspan. The wealthy have private health teams — AeonCircle gives one to everyone else. Curated regimens, personalized plans, and life insurance aligned with the next 120 years of your life." />
<link rel="canonical" href="https://aeoncircle.com/" />
<meta property="og:type" content="website" />
<meta property="og:url" content="https://aeoncircle.com/" />
<meta property="og:title" content="AeonCircle — Live well, for 120 years." />
<meta property="og:description" content="The healthspan club. One membership. Curated regimens, personalized plans, life insurance aligned with your next 120 years. We do the thinking. You live well." />
<meta property="og:site_name" content="AeonCircle" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content="AeonCircle — Live well, for 120 years." />
<meta name="twitter:description" content="The healthspan club. One membership. We do the thinking. You live well." />
<meta name="theme-color" content="#F0E6CC" />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Anybody:ital,wdth,wght@0,75..125,100..900;1,75..125,100..900&family=IBM+Plex+Mono:wght@300;400;500&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #F0E6CC;
    --bg-deep: #E8DDC0;
    --ink: #0E0E10;
    --ink-2: #2A2925;
    --muted: #6E6856;
    --yellow: #F4C12B;
    --yellow-soft: #FFD93D;
    --yellow-deep: #D9A91A;
    --aqua: #4DA6B0;
    --line: rgba(14, 14, 16, 0.12);
  }
  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; }
  body {
    background: var(--bg);
    color: var(--ink);
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
    min-height: 100vh;
    position: relative;
  }
  .bg {
    position: fixed; inset: 0; z-index: 0; overflow: hidden;
    background:
      radial-gradient(900px 700px at 50% 110%, rgba(244,193,43,0.18), transparent 65%),
      radial-gradient(700px 500px at 50% -10%, rgba(244,193,43,0.10), transparent 60%),
      var(--bg);
  }
  .bg::after {
    content: "";
    position: absolute; inset: -2px;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='160' height='160'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='2' stitchTiles='stitch'/><feColorMatrix values='0 0 0 0 0.06  0 0 0 0 0.05  0 0 0 0 0.04  0 0 0 0.08 0'/></filter><rect width='100%' height='100%' filter='url(%23n)'/></svg>");
    opacity: 0.7;
    pointer-events: none;
    mix-blend-mode: multiply;
  }
  .topbar, .botbar {
    position: relative; z-index: 3;
    border-top: 1px solid var(--ink);
    border-bottom: 1px solid var(--ink);
    background: var(--bg);
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px; font-weight: 400;
    letter-spacing: 0.28em; text-transform: uppercase;
    color: var(--ink);
    padding: 8px 20px;
    display: flex; justify-content: space-between; align-items: center; gap: 16px;
    overflow: hidden; white-space: nowrap;
  }
  .topbar span, .botbar span { display: inline-flex; align-items: center; gap: 8px; }
  .topbar .dot, .botbar .dot {
    display: inline-block; width: 7px; height: 7px;
    background: var(--yellow); border: 1px solid var(--ink);
    border-radius: 50%;
  }
  .halo {
    position: absolute; left: 50%; top: 52%;
    width: min(80vmin, 720px); aspect-ratio: 1/1;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle,
      rgba(244,193,43,0.30) 0%,
      rgba(244,193,43,0.12) 35%,
      rgba(244,193,43,0.02) 60%,
      transparent 75%);
    border-radius: 50%;
    filter: blur(36px);
    animation: breathe 9s ease-in-out infinite;
    pointer-events: none;
    z-index: 1;
  }
  @keyframes breathe {
    0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.9; }
    50%      { transform: translate(-50%, -50%) scale(1.10); opacity: 1; }
  }
  .watermark {
    position: absolute; left: 50%; top: 52%;
    width: min(78vmin, 680px); aspect-ratio: 1/1;
    transform: translate(-50%, -50%);
    pointer-events: none; z-index: 1;
    opacity: 0.10;
    color: var(--ink);
    animation: rotate-slow 90s linear infinite;
  }
  @keyframes rotate-slow {
    from { transform: translate(-50%, -50%) rotate(0deg); }
    to   { transform: translate(-50%, -50%) rotate(360deg); }
  }
  .dna-side {
    position: absolute; top: 0; bottom: 0;
    width: 80px;
    pointer-events: none; z-index: 1;
    opacity: 0.18;
    color: var(--ink);
  }
  .dna-side.left  { left: 0; }
  .dna-side.right { right: 0; transform: scaleX(-1); }

  .wrap {
    position: relative; z-index: 2;
    min-height: 100vh;
    display: flex; flex-direction: column;
  }
  header {
    display: flex; justify-content: space-between; align-items: center;
    padding: 22px 40px;
  }
  .brand {
    display: flex; align-items: center; gap: 12px;
    font-family: 'Anybody', sans-serif;
    font-weight: 700;
    font-variation-settings: "wdth" 115, "wght" 700;
    font-size: 17px; letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--ink);
  }
  .logo-mark { width: 30px; height: 30px; color: var(--ink); }
  .nav-meta {
    font-family: 'IBM Plex Mono', monospace;
    color: var(--ink);
    font-size: 11px; letter-spacing: 0.22em;
    text-transform: uppercase; opacity: 0.85;
  }
  .nav-meta::before {
    content: ""; display: inline-block;
    width: 7px; height: 7px;
    background: var(--yellow);
    border: 1px solid var(--ink);
    border-radius: 50%;
    margin-right: 8px;
    vertical-align: -1px;
  }
  main {
    flex: 1;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    text-align: center;
    padding: 48px 24px 80px;
    position: relative;
  }
  .eyebrow {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 7px 14px 6px;
    border: 1px solid var(--ink);
    background: var(--bg);
    color: var(--ink);
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10.5px; letter-spacing: 0.28em; text-transform: uppercase;
  }
  .eyebrow .pulse {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--yellow);
    border: 1px solid var(--ink);
    box-shadow: 0 0 0 0 rgba(244,193,43,0.55);
    animation: pulse 2.2s ease-out infinite;
  }
  @keyframes pulse {
    0%   { box-shadow: 0 0 0 0   rgba(244,193,43,0.55); }
    100% { box-shadow: 0 0 0 12px rgba(244,193,43,0); }
  }
  h1 {
    font-family: 'Anybody', sans-serif;
    font-size: clamp(72px, 16vw, 220px);
    line-height: 0.88;
    margin: 32px 0 4px;
    font-variation-settings: "wdth" 125, "wght" 900;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--ink);
    position: relative;
  }
  h1 .accent {
    color: var(--yellow);
    -webkit-text-stroke: 2px var(--ink);
  }
  .lead {
    font-family: 'Anybody', sans-serif;
    font-weight: 500;
    font-variation-settings: "wdth" 100, "wght" 500;
    font-size: clamp(22px, 2.6vw, 30px);
    color: var(--ink);
    letter-spacing: -0.01em;
    margin: 18px 0 30px;
    line-height: 1.2;
  }
  .lead em {
    font-style: normal;
    font-variation-settings: "wdth" 125, "wght" 800;
    background: var(--yellow);
    color: var(--ink);
    padding: 1px 10px 0;
    margin: 0 2px;
    display: inline-block;
    transform: skewX(-4deg);
  }
  .pitch {
    font-size: clamp(15px, 1.4vw, 17px);
    color: var(--ink-2);
    max-width: 600px;
    margin: 0 auto 40px;
    line-height: 1.78;
  }
  .pitch strong { color: var(--ink); font-weight: 600; }
  .pitch .hl { background: var(--yellow); color: var(--ink); padding: 0 4px; font-weight: 600; }
  .cta-row { display: flex; flex-direction: column; align-items: center; gap: 12px; }
  .cta {
    background: var(--ink);
    color: var(--bg);
    border: 1.5px solid var(--ink);
    padding: 14px 28px;
    font-family: 'Anybody', sans-serif;
    font-variation-settings: "wdth" 110, "wght" 700;
    font-size: 13px; letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none; cursor: pointer;
    display: inline-flex; align-items: center; gap: 12px;
    transition: transform .25s ease, background .25s ease, color .25s ease;
  }
  .cta .arrow { display: inline-block; transition: transform .25s ease; }
  .cta:hover {
    background: var(--yellow);
    color: var(--ink);
    transform: translateY(-1px);
  }
  .cta:hover .arrow { transform: translateX(4px); }
  .cta-note {
    font-family: 'IBM Plex Mono', monospace;
    color: var(--muted);
    font-size: 11px; letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .meta-row {
    margin-top: 56px;
    display: flex; gap: 22px;
    color: var(--ink);
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10.5px; letter-spacing: 0.26em; text-transform: uppercase;
    flex-wrap: wrap; justify-content: center;
  }
  .meta-row span { display: inline-flex; align-items: center; gap: 8px; }
  .meta-row span::before {
    content: ""; width: 6px; height: 6px;
    background: var(--yellow);
    border: 1px solid var(--ink);
    border-radius: 50%;
  }
  footer {
    padding: 18px 40px;
    display: flex; justify-content: space-between; align-items: center;
    color: var(--ink); font-family: 'IBM Plex Mono', monospace;
    font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase;
    border-top: 1px solid var(--ink);
    background: var(--bg);
    position: relative; z-index: 3;
  }
  footer a {
    color: var(--ink); text-decoration: none;
    transition: color .2s, background .2s;
    padding: 2px 4px;
  }
  footer a:hover { background: var(--yellow); }
  .fade { opacity: 0; transform: translateY(14px); animation: fade .9s ease forwards; }
  .fade.d1 { animation-delay: .15s; }
  .fade.d2 { animation-delay: .35s; }
  .fade.d3 { animation-delay: .55s; }
  .fade.d4 { animation-delay: .75s; }
  .fade.d5 { animation-delay: .95s; }
  .fade.d6 { animation-delay: 1.15s; }
  @keyframes fade { to { opacity: 1; transform: none; } }
  @media (max-width: 720px) {
    .dna-side { display: none; }
    header, footer { padding: 18px 20px; }
    .topbar, .botbar { padding: 8px 14px; font-size: 9px; letter-spacing: 0.18em; }
    .topbar span:nth-child(2), .botbar span:nth-child(2) { display: none; }
    .meta-row { gap: 14px; margin-top: 44px; }
    .pitch { font-size: 14.5px; }
    .lead em { transform: none; }
  }
</style>
</head>
<body>
  <div class="bg"></div>
  <svg class="dna-side left" viewBox="0 0 80 1000" preserveAspectRatio="xMidYMin slice" aria-hidden="true">
    <g fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round">
      <path d="M 20 0 C 20 20, 60 20, 60 60 C 60 100, 20 100, 20 120 C 20 140, 60 140, 60 180 C 60 220, 20 220, 20 240 C 20 260, 60 260, 60 300 C 60 340, 20 340, 20 360 C 20 380, 60 380, 60 420 C 60 460, 20 460, 20 480 C 20 500, 60 500, 60 540 C 60 580, 20 580, 20 600 C 20 620, 60 620, 60 660 C 60 700, 20 700, 20 720 C 20 740, 60 740, 60 780 C 60 820, 20 820, 20 840 C 20 860, 60 860, 60 900 C 60 940, 20 940, 20 960 L 20 1000"/>
      <path d="M 60 0 C 60 20, 20 20, 20 60 C 20 100, 60 100, 60 120 C 60 140, 20 140, 20 180 C 20 220, 60 220, 60 240 C 60 260, 20 260, 20 300 C 20 340, 60 340, 60 360 C 60 380, 20 380, 20 420 C 20 460, 60 460, 60 480 C 60 500, 20 500, 20 540 C 20 580, 60 580, 60 600 C 60 620, 20 620, 20 660 C 20 700, 60 700, 60 720 C 60 740, 20 740, 20 780 C 20 820, 60 820, 60 840 C 60 860, 20 860, 20 900 C 20 940, 60 940, 60 960 L 60 1000"/>
      <g stroke-width="1">
        <line x1="20" y1="0"   x2="60" y2="0"/>
        <line x1="20" y1="120" x2="60" y2="120"/>
        <line x1="20" y1="240" x2="60" y2="240"/>
