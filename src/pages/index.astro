<script>
  // Reveal on scroll
  const obs = new IntersectionObserver(es => {
    es.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in'); obs.unobserve(e.target); } });
  }, { threshold: 0.12, rootMargin: '0px 0px -60px 0px' });
  document.querySelectorAll('.reveal').forEach(r => obs.observe(r));

  // Language toggle
  const TITLES = {
    en: 'AeonCircle — A private healthspan club',
    zh: 'AeonCircle — 私人健康會員'
  };
  function toggleLang() {
    const html = document.documentElement;
    const isZh = html.classList.contains('lang-zh');
    html.classList.toggle('lang-zh', !isZh);
    html.classList.toggle('lang-en', isZh);
    html.lang = isZh ? 'en' : 'zh-Hant';
    document.title = isZh ? TITLES.en : TITLES.zh;
    try { localStorage.setItem('aeoncircle-lang', isZh ? 'en' : 'zh'); } catch(e) {}
  }
  // Bind to window so inline handlers still work
  window.toggleLang = toggleLang;
  // Bind via addEventListener (the robust path — module scripts otherwise lose globals)
  document.getElementById('lang-toggle')?.addEventListener('click', toggleLang);
  // Sync title on first load if saved was zh
  if (document.documentElement.classList.contains('lang-zh')) {
    document.title = TITLES.zh;
  }
</script>

