    </g>
  </svg>
  <svg class="dna-side right" viewBox="0 0 80 1000" preserveAspectRatio="xMidYMin slice" aria-hidden="true">
    <g fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round">
      <path d="M 20 0 C 20 20, 60 20, 60 60 C 60 100, 20 100, 20 120 C 20 140, 60 140, 60 180 C 60 220, 20 220, 20 240 C 20 260, 60 260, 60 300 C 60 340, 20 340, 20 360 C 20 380, 60 380, 60 420 C 60 460, 20 460, 20 480 C 20 500, 60 500, 60 540 C 60 580, 20 580, 20 600 C 20 620, 60 620, 60 660 C 60 700, 20 700, 20 720 C 20 740, 60 740, 60 780 C 60 820, 20 820, 20 840 C 20 860, 60 860, 60 900 C 60 940, 20 940, 20 960 L 20 1000"/>
      <path d="M 60 0 C 60 20, 20 20, 20 60 C 20 100, 60 100, 60 120 C 60 140, 20 140, 20 180 C 20 220, 60 220, 60 240 C 60 260, 20 260, 20 300 C 20 340, 60 340, 60 360 C 60 380, 20 380, 20 420 C 20 460, 60 460, 60 480 C 60 500, 20 500, 20 540 C 20 580, 60 580, 60 600 C 60 620, 20 620, 20 660 C 20 700, 60 700, 60 720 C 60 740, 20 740, 20 780 C 20 820, 60 820, 60 840 C 60 860, 20 860, 20 900 C 20 940, 60 940, 60 960 L 60 1000"/>
      <g stroke-width="1">
        <line x1="20" y1="0"   x2="60" y2="0"/>
        <line x1="20" y1="120" x2="60" y2="120"/>
        <line x1="20" y1="240" x2="60" y2="240"/>
        <line x1="20" y1="360" x2="60" y2="360"/>
        <line x1="20" y1="480" x2="60" y2="480"/>
        <line x1="20" y1="600" x2="60" y2="600"/>
        <line x1="20" y1="720" x2="60" y2="720"/>
        <line x1="20" y1="840" x2="60" y2="840"/>
        <line x1="20" y1="960" x2="60" y2="960"/>
      </g>
    </g>
  </svg>
  <svg class="watermark" viewBox="0 0 64 64" aria-hidden="true">
    <circle cx="32" cy="32" r="28" fill="none" stroke="currentColor" stroke-width="1.2"/>
    <path d="M 22 14 C 22 22, 42 22, 42 32 C 42 42, 22 42, 22 50" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
    <path d="M 42 14 C 42 22, 22 22, 22 32 C 22 42, 42 42, 42 50" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
    <line x1="22" y1="14" x2="42" y2="14" stroke="currentColor" stroke-width="1"/>
    <line x1="22" y1="32" x2="42" y2="32" stroke="currentColor" stroke-width="1"/>
    <line x1="22" y1="50" x2="42" y2="50" stroke="currentColor" stroke-width="1"/>
  </svg>
  <div class="halo" aria-hidden="true"></div>

  <div class="wrap">
    <div class="topbar">
      <span><span class="dot"></span>ÆONCIRCLE™ · A HEALTHSPAN MEMBERSHIP</span>
      <span>FORMING · MMXXVI</span>
      <span>LOT N° 001</span>
    </div>

    <header class="fade">
      <div class="brand">
        <svg class="logo-mark" viewBox="0 0 64 64" aria-hidden="true">
          <circle cx="32" cy="32" r="28" fill="none" stroke="currentColor" stroke-width="2.5"/>
          <path d="M 22 16 C 22 22, 42 22, 42 32 C 42 42, 22 42, 22 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          <path d="M 42 16 C 42 22, 22 22, 22 32 C 22 42, 42 42, 42 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          <line x1="22" y1="16" x2="42" y2="16" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
          <line x1="22" y1="32" x2="42" y2="32" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
          <line x1="22" y1="48" x2="42" y2="48" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
        </svg>
        <span>AeonCircle</span>
      </div>
      <div class="nav-meta">The Healthspan Club</div>
    </header>

    <main>
      <div class="eyebrow fade d1">
        <span class="pulse"></span>
        <span>Membership N° 001 · Now Forming</span>
      </div>

      <h1 class="fade d2">
        Aeon<span class="accent">Circle</span>
      </h1>

      <p class="lead fade d3">
        Live well — for <em>120 years</em>.
      </p>

      <p class="pitch fade d4">
        The wealthy have private health teams.
        <strong>AeonCircle gives one to everyone else</strong> —
        a single membership of <span class="hl">vetted regimens</span>,
        personalized plans, and life insurance aligned with your healthspan.
        <br/><br/>
        You live well. We do the thinking.
      </p>

      <div class="cta-row fade d5">
        <a class="cta" href="mailto:angel.alipay2011@gmail.com?subject=AeonCircle%20%E2%80%94%20Invitation%20request&amp;body=Hi%20%E2%80%94%20I%27d%20like%20to%20join%20the%20founding%20circle.%0A%0AA%20little%20about%20me%3A%0A">
          <span class="label">Request invitation</span>
          <span class="arrow">→</span>
        </a>
        <span class="cta-note">Founding membership · Opens soon</span>
      </div>

      <div class="meta-row fade d6">
        <span>Membership</span>
        <span>Vetted</span>
        <span>Covered</span>
        <span>120 Years</span>
      </div>
    </main>

    <div class="botbar">
      <span><span class="dot"></span>LIVE WELL · LIVE LONG</span>
      <span>AEONCIRCLE.COM</span>
      <span>MFG. MMXXVI</span>
    </div>

    <footer class="fade d6">
      <div>© 2026 AeonCircle</div>
      <div><a href="mailto:angel.alipay2011@gmail.com">angel.alipay2011@gmail.com →</a></div>
    </footer>
  </div>
</body>
</html>
